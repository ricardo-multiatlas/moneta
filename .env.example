# Variables de entorno · Correduría OS
# Copiar a .env (NO commitear) y rellenar con valores reales.
# .env está en .gitignore — NUNCA subir credenciales al repo.
#
# Todos los proveedores externos tienen datacenter UE para cumplir
# soberanía del dato (Bloque 8 de la propuesta MultiAtlas).

# Supabase (EU · eu-west-3 París)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:URL_ENCODED_PASSWORD@aws-1-eu-west-3.pooler.supabase.com:6543/postgres

# Brevo (emails transaccionales y campañas · ex-Sendinblue, datacenters Francia)
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=avisos@tudominio.es
BREVO_FROM_NAME=Moneta Seguros

# Mistral La Plateforme (IA · empresa francesa, datacenters Francia y Suecia)
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...
