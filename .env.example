# Variables de entorno · Correduría OS
# Copiar a .env (NO commitear) y rellenar con valores reales.
# .env está en .gitignore — NUNCA subir credenciales al repo.

# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres

# Resend (emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notificaciones@tudominio.es

# Gemini (IA extracción PDF)
GOOGLE_GENERATIVE_AI_API_KEY=...
