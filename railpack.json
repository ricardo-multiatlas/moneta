{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20"
  },
  "steps": {
    "install": {
      "commands": [
        "npm ci --no-audit --no-fund"
      ]
    },
    "build": {
      "commands": [
        "npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "node server-node.mjs"
  }
}
